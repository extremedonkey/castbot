#!/bin/bash
# 🗿 The Moai Pre-Commit Hook
# Rejects commits that ADD new legacy button handlers to app.js.
# Legacy = `} else if (custom_id` NOT followed by ButtonHandlerFactory.create within 3 lines.
#
# See: docs/enablers/ButtonHandlerFactory.md
# See: CLAUDE.md "Button Handler Factory" section

BASELINE=125  # Legacy handler count as of 2026-03-15. Excludes MODAL_SUBMIT section (82 modal handlers). Only goes DOWN.

# ── Auto-sync: keep installed hook in sync with source ──
SOURCE_HOOK="scripts/hooks/pre-commit"
INSTALLED_HOOK=".git/hooks/pre-commit"
if [ -f "$SOURCE_HOOK" ] && [ -f "$INSTALLED_HOOK" ]; then
  SOURCE_BASELINE=$(grep '^BASELINE=' "$SOURCE_HOOK" | head -1)
  INSTALLED_BASELINE=$(grep '^BASELINE=' "$INSTALLED_HOOK" | head -1)
  if [ "$SOURCE_BASELINE" != "$INSTALLED_BASELINE" ]; then
    # Source was updated but installed copy is stale — sync it
    cp "$SOURCE_HOOK" "$INSTALLED_HOOK" && chmod +x "$INSTALLED_HOOK"
    # Re-exec with the updated hook
    exec "$INSTALLED_HOOK" "$@"
  fi
fi

# Skip if app.js isn't being committed
if ! git diff --cached --name-only | grep -q '^app\.js$'; then
  exit 0
fi

# ── Check 1: Legacy handler count (must not go UP) ──
# Counts `} else if (custom_id` blocks NOT followed by ButtonHandlerFactory.create within 3 lines.
# Skips the MODAL_SUBMIT section — modal submit handlers legitimately use res.send() directly.
LEGACY_COUNT=$(git show :app.js | awk '
/type === InteractionType\.MODAL_SUBMIT/ { in_modal_submit = 1 }
in_modal_submit && /^  \}$/ { in_modal_submit = 0 }
/} else if \(custom_id/ && !/^[[:space:]]*\/\// && !in_modal_submit {
  handler_line = NR;
  is_factory = 0;
}
handler_line && NR > handler_line && NR <= handler_line + 3 {
  if (/ButtonHandlerFactory\.create/) is_factory = 1;
}
handler_line && NR == handler_line + 3 {
  if (!is_factory) legacy_count++;
  handler_line = 0;
}
END { print legacy_count }
')

BLOCKED=0

if [ "$LEGACY_COUNT" -gt "$BASELINE" ]; then
  echo ""
  echo "🗿 THE MOAI SPEAKS."
  echo ""
  echo "  You added $((LEGACY_COUNT - BASELINE)) new legacy handler(s) to app.js."
  echo "  Legacy handlers: $LEGACY_COUNT (baseline: $BASELINE)"
  echo ""
  echo "  ┌─────────────────────────────────────────────────────┐"
  echo "  │ HOW TO FIX — wrap your handler in the factory:      │"
  echo "  │                                                     │"
  echo "  │  } else if (custom_id === 'my_button') {            │"
  echo "  │    return ButtonHandlerFactory.create({              │"
  echo "  │      id: 'my_button',                               │"
  echo "  │      updateMessage: true,                           │"
  echo "  │      handler: async (context) => {                  │"
  echo "  │        const { guildId, userId } = context;         │"
  echo "  │        return { content: 'Done!' };                 │"
  echo "  │      }                                              │"
  echo "  │    })(req, res, client);                            │"
  echo "  │  }                                                  │"
  echo "  │                                                     │"
  echo "  │ For modals: return { type: MODAL, data: {...} }     │"
  echo "  │ from the factory handler — it supports modal        │"
  echo "  │ responses too!                                      │"
  echo "  │                                                     │"
  echo "  │ Docs: docs/enablers/ButtonHandlerFactory.md         │"
  echo "  └─────────────────────────────────────────────────────┘"
  echo ""
  echo "  DO NOT change the BASELINE to bypass this hook."
  echo "  The baseline only goes DOWN when legacy handlers are migrated."
  echo ""
  BLOCKED=1
fi

# ── Check 2: No new ActionRow+TextInput in modals (use Label type 18) ──
# Only check newly added lines (+ lines in the diff)
NEW_LEGACY_MODALS=$(git diff --cached -- app.js | grep '^+' | grep -v '^+++' | \
  grep -c 'type: 1.*components.*type: 4\|type: 1, *$' 2>/dev/null || echo 0)

# Only warn if there are new ActionRow patterns wrapping TextInputs
if [ "$NEW_LEGACY_MODALS" -gt 0 ]; then
  # Check if these are actually ActionRow+TextInput combos (not just ActionRow+Button)
  ACTUAL_LEGACY=$(git diff --cached -- app.js | grep '^+' | grep -v '^+++' | \
    grep -c 'type: 1.*components.*\[.*{.*type: 4' 2>/dev/null || echo 0)
  if [ "$ACTUAL_LEGACY" -gt 0 ]; then
    echo ""
    echo "🗿 THE MOAI ALSO NOTICES..."
    echo ""
    echo "  You're using ActionRow + TextInput (type 1 + type 4) in modals."
    echo "  Use Label wrappers (type 18) instead — they support descriptions."
    echo ""
    echo "  Old: { type: 1, components: [{ type: 4, ... }] }"
    echo "  New: { type: 18, label: '...', description: '...', component: { type: 4, ... } }"
    echo ""
    echo "  (This is a warning — commit is not blocked for this.)"
    echo ""
  fi
fi

if [ "$BLOCKED" -eq 1 ]; then
  exit 1
fi

# ── Check 3: New JS modules should have tests (warning, not blocking) ──
# Checks if any new .js files are being committed without a matching tests/*.test.js
NEW_JS_FILES=$(git diff --cached --name-only --diff-filter=A | grep '^\w.*\.js$' | grep -v '^tests/' | grep -v 'node_modules' | grep -v '^scripts/' | grep -v '^poc/' | grep -v '^temp/' | grep -v '^docs/')
if [ -n "$NEW_JS_FILES" ]; then
  UNTESTED_FILES=""
  for jsfile in $NEW_JS_FILES; do
    basename=$(basename "$jsfile" .js)
    if [ ! -f "tests/${basename}.test.js" ] && ! git diff --cached --name-only | grep -q "tests/${basename}.test.js"; then
      UNTESTED_FILES="$UNTESTED_FILES  - $jsfile (expected: tests/${basename}.test.js)\n"
    fi
  done
  if [ -n "$UNTESTED_FILES" ]; then
    echo ""
    echo "🗿 THE MOAI NOTICES UNTESTED CODE..."
    echo ""
    echo "  New module(s) without test files:"
    echo -e "$UNTESTED_FILES"
    echo "  CLAUDE.md says: 'Write tests for every new feature.'"
    echo "  Tests run on every dev-restart — untested code is unverified code."
    echo ""
    echo "  (This is a warning — commit is not blocked for this.)"
    echo ""
  fi
fi

# Celebrate if someone migrated handlers
if [ "$LEGACY_COUNT" -lt "$BASELINE" ]; then
  MIGRATED=$((BASELINE - LEGACY_COUNT))
  echo "🗿 The Moai approves. $MIGRATED legacy handler(s) migrated. (${LEGACY_COUNT} remain)"
  echo "   Update BASELINE to $LEGACY_COUNT in scripts/hooks/pre-commit to lock in progress."
fi

exit 0
