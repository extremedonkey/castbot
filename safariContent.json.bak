      "visit_home_154522": {
        "id": "visit_home_154522",
        "name": "Visit Home",
        "label": "Visit Home",
        "emoji": "🛖",
        "style": "Primary",
        "actions": [
          {
            "type": "display_text",
            "order": 0,
            "config": {
              "title": "One last visit home..",
              "content": "The village hums with the last sounds of evening: laughter around cookfires, the thump of drums, waves folding softly against the reef. Inside your family fale, bundles are tied, farewells already spoken. This time, you’re not just sailing out to fish.\n\nYour grandfather reaches for a small woven purse, hands weathered by salt and sun. With a knowing smile, he tips it over your outstretched palm — shell-coins and carved tokens clink into your hand, warm from their touch.\n\n> “The sea is wide, but our blood is wider,” he murmurs. “Spend these wisely. Bring back stories we’ve never heard before.”\n\nOutside, your canoe waits at the water’s edge. The night breeze smells of salt, smoke… and possibility.",
              "image": "https://cdn.discordapp.com/attachments/1418593743514243193/1441090622147526798/content.png?ex=692087ba&is=691f363a&hm=223192d336ae92c10a520a903cebf50053ad6e2c13170d46bbdc5257558d8604&",
              "color": "#F59E0B"
            },
            "executeOn": "true"
          },
          {
            "type": "give_currency",
            "order": 1,
            "config": {
              "amount": 10,
              "limit": {
                "type": "once_per_player",
                "claimedBy": []
              }
            },
            "executeOn": "true"
          }
        ],
        "trigger": {
          "type": "button",
          "button": {
            "label": "Visit Home",
            "emoji": "🛖",
            "style": "Secondary"
          }
        },
        "conditions": {
          "logic": "AND",
          "items": []
        },
        "coordinates": [
