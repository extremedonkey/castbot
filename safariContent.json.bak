      "talk_to_ferdinand_942281": {
        "id": "talk_to_ferdinand_942281",
        "name": "Talk to Ferdinand",
        "label": "Talk to Ferdinand",
        "emoji": null,
        "style": "Primary",
        "actions": [
          {
            "type": "display_text",
            "order": 0,
            "config": {
              "title": "Did you get one",
              "content": "\"Professor! It's good to see you. I was just working on some of my lance skills before I head out to the Gloucester Front. Have you seen the marketplace lately? Selling a sword and an axe! I know they are broken but... seems pretty important to me. Here - take some money to get one if you haven't yet.\"",
              "image": "https://static.wikia.nocookie.net/fireemblem/images/2/21/Ferdinand_Portrait_5_Years.png/revision/latest/scale-to-width-down/250?cb=20200414184004"
            },
            "executeOn": "true"
          },
          {
            "type": "give_currency",
            "order": 1,
            "config": {
              "amount": 50,
              "limit": {
                "type": "once_per_player",
                "claimedBy": []
              }
            },
            "executeOn": "true"
          }
        ],
        "trigger": {
