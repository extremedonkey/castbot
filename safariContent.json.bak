          "C4": {
            "channelId": "1431901335250538630",
            "baseContent": {
              "title": "🏛️ C4 Reception Hall",
              "description": "The Reception Hall has large, looming ceilings with windows that allow the light to shine through onto the tiled floor. Large chandeliers hang above benches where students mingle and discuss the day. Their candles flicker lazily. \n\nPacing through the hallway is Hilda. She seems to be holding something in her hands as she walks.",
              "image": "https://pbs.twimg.com/media/EPUPOqSUYAE4ebG?format=jpg&name=large",
