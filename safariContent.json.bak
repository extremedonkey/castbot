      "interrupt_their_conv_602080": {
        "id": "interrupt_their_conv_602080",
        "name": "Interrupt Their Conversation",
        "label": "Interrupt Their Conversation",
        "emoji": "🗣️",
        "style": "Primary",
        "actions": [
          {
            "type": "display_text",
            "order": 0,
            "config": {
              "title": "Solve The Argument",
              "content": "Turns out the animals are discussing which of them has the better view of the volcano. The turtle says its better looking from the water. The ram...thinks it looks better up close. \n\nWelp. Only way to settle this is by looking at it from both perspectives. \n\nTo succeed at this task, complete this puzzle before moving to another place on the map. You have as much time as you need. Send us a screenshot of your completed puzzle when you are done. \n\nhttps://www.jigsawplanet.com/?rc=play&pid=2fc3bf04ed5c\n\nWe should be able to tell the screenshot is from today",
              "image": ""
            },
            "executeOn": "true"
