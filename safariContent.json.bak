      "do_all_the_things_307836": {
        "id": "do_all_the_things_307836",
        "name": "Talk to Elder",
        "label": "Do all the things",
        "emoji": "🧓🏻",
        "style": "Primary",
        "actions": [
          {
            "type": "display_text",
            "order": 0,
            "config": {
              "title": "🧓🏼 You speak to the village elder",
              "content": "An old man sits above the high-tide line, carving slow circles into a piece of driftwood. When you approach, he nods toward the open water.\n\n> “Everyone wants to race for the farthest islands,” he says. “But some waters are hunting grounds. When your charts show sharks, treat those areas differently. Think of exactly why you’re risking it.”\n\nHe holds your gaze a moment longer.\n\n> “Reefs cut, storms scare… but sharks decide. Respect the fins, voyager, or the sea will keep you.”",
              "image": "https://cdn.discordapp.com/attachments/1418593743514243193/1440738253236863027/content.png?ex=691f3f8f&is=691dee0f&hm=89a07cac4345601f8f266b656003fffbaec6f8d4a6551e6967981c02a037962a&",
              "color": "#0C4A6E"
            },
            "executeOn": "true"
          }
        ],
        "trigger": {
          "type": "button",
