          "lastModified": 1761462566174,
          "totalSold": 0
        }
      },
      "tide_sigil_moonlit_s_393514": {
        "id": "tide_sigil_moonlit_s_393514",
        "name": "Moonlit Scale",
        "description": "A silvery scale, slick with sea sheen, reflecting light in moonlike hues. Said to have fallen from a sacred sea beast glimpsed once in a century. When placed in water, it hums with quiet power, drawing tides in unnatural rhythm.",
