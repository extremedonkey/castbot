          "E5": {
            "channelId": "1431901396831305778",
            "baseContent": {
              "title": "⚔️ E5 Training Grounds",
              "description": "Weapons clash against each other and training dummies as students practice their different skills in the Training Grounds. Arrows fly past, shooting their targets. \n\nCaspar is in the middle of the training grounds mid duel with Felix. Leonie watches on the side, her eyes following the moves of the two fighters carefully.\n\nSeteth stands near the edge of the area pacing. He seems to be deep in thought.",
              "image": "https://resource.supercheats.com/library/supercheats/740w/2019/1565389915b_tournament1.webp",
              "clues": []
            },
