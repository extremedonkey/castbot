          "C3": {
            "channelId": "1431901299443630120",
            "baseContent": {
              "title": "🛏️ C3 | Dormitory",
              "description": "Tucked away in a quieter wing of Garreg Mach Monastery, the Commoner Dormitories offer simple yet functional living quarters for students. Students lounge on the lawn outside or come and go from their rooms throughout the day - and night.",
              "image": "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcTg_U4uz1WvOjv9tx1NP_0nbQTIGDzEt-_I8w&s",
