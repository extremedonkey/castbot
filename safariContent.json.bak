  "1431897593771982870": {
    "buttons": {
      "enquire_to_see_what__876806": {
        "id": "enquire_to_see_what__876806",
        "name": "Enquire to see what he wants..",
        "label": "Enquire to see what he wants..",
        "emoji": "❔",
        "style": 3,
        "actions": [
          {
            "type": "display_text",
            "order": 0,
            "config": {
              "title": "Someone's got a crushh....",
              "content": "> \"Er, you didn’t see me lookin’ her way, did you? It’s just... well, Lady Edelgard passed by here the other day and—ah, never mind.\"\n\n[He clears his throat and hastily holds up a slightly bruised apple.]\n\nFisherman:\n\"Think you could give her this? It’s not much, but it’s... shiny. Like her armor. Tell her it’s from... a friend of the fish.\"\n(He looks away awkwardly.)",
              "image": "",
              "color": "00ff00"
            },
            "executeOn": "true"
          },
          {
            "type": "give_item",
