          "B3": {
            "channelId": "1431901297094688778",
            "baseContent": {
              "title": "🌷 B3 | Greenhouse",
              "description": "The smell of fresh herbs, flowers, fruits and vegetables fills the Greenhouse. It is considerably hotter inside the Greenhouse than the rest of Garreg Mach. Large windows surround the building, allowing in as much natural light as possible for the plants to blossom and bloom.\n\nThe Greenhouse Keeper stands in the middle of the Greenhouse and smiles at you as you enter.",
              "image": "https://i.ytimg.com/vi/AsvxDMs9Yqo/maxresdefault.jpg",
