          "F1": {
            "channelId": "1400526790631493744",
            "baseContent": {
              "title": "🌊 F1 | Rocky Waters",
              "description": "The ocean is harsher here. It seems as though there's a storm on the horizon. \n\nIf you turn back towards the island chain, it'll be safe sailing. \n\nIf you go towards the storm, though...risk and reward awaits",
              "image": null,
              "clues": []
            },
            "buttons": [],
