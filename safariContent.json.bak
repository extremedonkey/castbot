        "label": "Talk to Marianne",
        "emoji": null,
        "style": "Primary",
        "actions": [
          {
            "type": "display_text",
            "order": 0,
            "config": {
              "title": "Hello, Professor",
              "content": "\"Oh... hel-lo Professor.. I am so sorry if I am in your way. I just... needed some time away. The infimary is becoming a morgue and I needed to... get... away. I stopped by the Blacksmith. He has been selling a lot of weapons lately. He... still has some broken swords. And axes. You... I think you should get one.\"",
              "image": "https://static.wikia.nocookie.net/p__/images/f/fb/Marianne_Portrait_5_Years.png/revision/latest?cb=20210831034609&path-prefix=protagonist"
