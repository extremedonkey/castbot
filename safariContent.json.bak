      "spiral_of_echoes_350510": {
        "id": "spiral_of_echoes_350510",
        "name": "Dragon Sign",
        "description": "If a unit has a Dragon Sign in their inventory, then said unit will gain the effects of that Dragon Sign's Crest, as if the unit naturally has said Crest. If the unit already has a Crest, both their natural Crest and the Dragon Sign can activate. Having a Dragon Sign item also allows Crest-less units to use any of the Heroes' Relics without taking damage.",
        "emoji": "🌀",
        "category": "General",
        "basePrice": 0,
        "maxQuantity": -1,
        "consumable": "No",
        "metadata": {
