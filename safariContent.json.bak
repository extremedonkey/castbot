          "B5": {
            "channelId": "1431901369601757258",
            "baseContent": {
              "title": "🛒 B5 Marketplace",
              "description": "The Marketplace is a bustling centre with different vendors to choose from and different wares to purchase. Here, you can get anything from weapons, to herbs and vegetables, to gifts! All for the right price. One student you recognize right as you enter, as you see Petra is looking at some of the vegetables at a stall.\n\nOn the steps to the building Flayn is sitting with her head in her hands.",
              "image": "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcS0S07kNnmOixblLEQws34pCTUO8eQy_Tud0Q&s",
