      "give_her_some_rock_907017": {
        "id": "give_her_some_rock_907017",
        "name": "Give her some rock",
        "label": "Give her some rock",
        "emoji": "🌋",
        "style": "Primary",
        "actions": [
          {
            "type": "display_text",
            "order": 0,
            "config": {
              "title": "🌋 From Volcano to Vessel",
              "content": "The moment you step back into the shop, the old woman’s eyes drop to your pack.\nA slow, knowing smile tugs at the corner of her mouth.\n\n“Back from the volcano, are you?” she says, holding out a weathered hand. “Let me see what the mountain gave you.”\n\nYou place the volcanic rock on her workbench. She turns it over, taps it with a knuckle, then nods, satisfied.\n\n“Solid. The kind of stone that’s met fire and didn’t flinch. This’ll hold a canoe together when lesser hulls splinter.”\n\nHer gaze shifts to your coin pouch.\n“Craft like this doesn’t come free, mind you. Two hundred gold, and I’ll make your little raft into something that can face the real ocean.”\n\nYou count out the coins. She sweeps them away without another word and gets to work.\n\nFor a while, all you hear is scraping, carving, and the crackle of heated resin. She binds slivers of dark stone into the hull, reinforces the outriggers, and fixes a new, sharp-cut prow that looks ready to bite into the swell.\n\nAt last, she steps aside.\n\n“There,” she says. “Now you’re sailing a *flying* canoe. The shallow shores were all you could handle before… but this one will carry you across deeper channels and rougher reefs. Just remember—”\n\nShe taps the hull once, firmly.\n\n> “The ocean might let you cross… but it never promises to bring you back.”",
              "image": "https://cdn.discordapp.com/attachments/1418593743514243193/1440731305452245126/content.png?ex=691f3916&is=691de796&hm=bedfd700d99de1f409a048c283c59e4cd47061435e86022f308876d9804d27ed&",
              "color": "ff0000"
            },
            "executeOn": "true"
          },
          {
            "type": "give_item",
            "order": 1,
            "config": {
              "itemId": "va_a_lele_flying_can_928219",
              "quantity": 1,
              "limit": {
                "type": "once_per_player",
                "claimedBy": []
              }
            },
            "executeOn": "true"
          },
          {
            "type": "give_currency",
            "order": 2,
            "config": {
              "amount": -200,
              "limit": {
                "type": "once_per_player",
                "claimedBy": []
              }
            },
            "executeOn": "true"
          },
          {
            "type": "display_text",
            "order": 3,
            "config": {
              "title": "Nice try, kid",
              "content": "The Craftswoman looks at you empty handed, defying her earlier instructions. She shakes her head.",
              "image": "",
              "color": "#ff0000"
            },
            "executeOn": "false"
          }
        ],
        "trigger": {
          "type": "button",
          "button": {
            "label": "Give her some rock",
            "emoji": "🌋",
            "style": "Secondary"
          }
        },
        "conditions": [
          {
            "id": "cond_1763566925440_j5je2",
            "type": "currency",
            "operator": "gte",
            "value": 200,
            "logic": "AND"
          },
          {
            "id": "cond_1763566948371_0pxn2",
            "type": "item",
            "operator": "has",
            "logic": "AND",
            "itemId": "tide_forged_obsidian_773156"
          }
        ],
        "coordinates": [
