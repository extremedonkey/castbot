          "E1": {
            "channelId": "1400526767030272157",
            "baseContent": {
              "title": "🎲 E1 | Gambling Game",
              "description": "Hey, there are people already on this island!\n\nThere's a group of old men sitting under a palm tree playing some sort of card and dice game. \n\nThey say they don't have anywhere for you to stay, so you'll have to continue your journey. \n\nBUT...if you can beat them at their game, they say they have a prize for you...",
              "image": null,
              "clues": []
            },
            "buttons": [
              "let_s_gamble_bitches_927895"
