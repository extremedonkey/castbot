      "talk_to_sylvain_126134": {
        "id": "talk_to_sylvain_126134",
        "name": "Talk to Sylvain",
        "label": "Talk to Sylvain",
        "emoji": null,
        "style": "Primary",
        "actions": [
          {
            "type": "display_text",
            "order": 0,
            "config": {
              "title": "A Lily!",
              "content": "\"Professor is that a Lily you have on you? I've been wanting one for a while now. Do you think I could have it. Here - I'll give you some money in return. It's just... nice to have something pretty to look at out here. Not many girls around, you know.\"",
              "image": "https://fe3h.noobsaigon.com/sylvain_l@4x-3.png"
            },
            "executeOn": "true"
          },
          {
            "type": "give_currency",
            "order": 1,
            "config": {
              "amount": 50,
              "limit": {
                "type": "once_per_player",
                "claimedBy": []
              }
            },
            "executeOn": "true"
          },
          {
            "type": "display_text",
            "order": 2,
            "config": {
              "title": "\"Hey Professor\"",
              "content": "\"Hey Professor. It's nice to see your face out in these parts. Not exactly anything else nice to look at. You know - I've actually really been wanting to see a Lily. I don't know why, but it's all I can think about.\"",
              "image": "https://fe3h.noobsaigon.com/sylvain_l@4x-3.png"
            },
            "executeOn": "false"
          }
        ],
        "trigger": {
          "type": "button",
          "button": {
            "label": "Talk to Sylvain",
            "emoji": null,
            "style": "Primary"
          }
        },
        "conditions": [
          {
            "id": "cond_1755615134820_jj1l8",
