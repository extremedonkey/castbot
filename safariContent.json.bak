          "B1": {
            "channelId": "1400526760428437515",
            "baseContent": {
              "title": "🐋B1 | The Wise Whale",
              "description": "🐋A great blue whale rises from the ocean. Its eyes glimmer with the sparkle of someone who knows something you do not. It speaks in a low tone, though you're unable to decipher where exactly the words are coming from...\n\n\"If it's a prize you seek, I am of no value to you. \n\nIf it is knowledge of your journey, however, I will offer you what I can.\"",
              "image": null,
              "clues": []
            },
            "buttons": [
              "ask_about_boats_942187",
              "drop_a_line_734262",
              "ask_about_treasure_430748"
            ],
            "hiddenCommands": {},
