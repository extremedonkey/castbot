        "coordinates": {
          "A1": {
            "channelId": "1400526758163513374",
            "baseContent": {
              "title": "🏝️ A1 | The Start of Your Journey",
              "description": "A bustling civilization lies restless. Too many people, not enough space. \n\nThe temptation of exploration is too great to hold you for long. \n\nAlong your journey, you'll find many things. Friends and foes. Treasures and trials. But it's the raw power these islands contain that can bring you to the top of this game. \n\nGo forth. The great blue sea awaits.",
              "image": "",
              "clues": []
            },
            "buttons": [
              "do_all_the_things_307836",
              "visit_home_154522",
              "initial_name_1772219997582",
