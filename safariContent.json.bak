            "label": "Do all the things",
            "emoji": "😪",
            "style": "Secondary"
          }
        },
        "conditions": {
          "logic": "AND",
          "items": []
        },
        "coordinates": [
          "A1"
        ],
        "description": "Gives player advice to avoid sharks",
        "metadata": {
          "createdBy": null,
          "createdAt": 1763961252721,
          "lastModified": 1763961252721,
          "usageCount": 0,
          "tags": []
        }
      },
