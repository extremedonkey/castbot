        }
      },
      "emberbrand_relic_485500": {
        "id": "emberbrand_relic_485500",
        "name": "Crest Stone",
        "description": "Originally, Crest Stones were the hearts of dragons that lived in ancient times; being their hearts, they naturally contained much of their power and allowed them to take on their dragon forms. Crest Stones are the main source of power for the legendary Heroes' Relics.",
