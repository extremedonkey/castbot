          "E2": {
            "channelId": "1400526823535673457",
            "baseContent": {
              "title": "🐋E2 | Trickster Whale",
              "description": "A beluga whale pokes his head out of the water, rocking your boat as it peers across your bow. \n\nA wry smirk crosses its face, like it knows something you don't somehow...despite, ya know, being a whale and all. \n\nThen it speaks, saying the following: \n\n\"Answer my riddle, and my legacy will be yours. \n\nFail, and I'll steal your oars.\"\n\nSteal my oars what the hell...Better be confident in that riddle.",
              "image": null,
              "clues": []
            },
            "buttons": [
              "the_whale_s_riddle_277419"
